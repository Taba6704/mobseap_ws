<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="usv">

  <!-- Basic dimensions -->
  <xacro:property name="hull_length" value="1.0"/>
  <xacro:property name="hull_width" value="0.45"/>
  <xacro:property name="hull_height" value="0.20"/>

  <xacro:property name="camera_size" value="0.08"/>

  <!-- Water plane size -->
  <xacro:property name="water_length" value="60.0"/>
  <xacro:property name="water_width" value="60.0"/>
  <xacro:property name="water_thickness" value="0.02"/>

  <!-- Base hull -->
  <link name="base_link">
    <visual>
      <origin xyz="-0.5 0.65 -0.25" rpy="1.5708 0 0.0"/>
      <geometry>
        <mesh filename="package://usv_sim/meshes/boat_hull.STL" scale="1.25 1.25 1.25"/>
      </geometry>
      <material name="gray">
        <color rgba="0.6 0.6 0.6 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0.0" rpy="0 0 0"/>
      <geometry>
        <box size="${hull_length} ${hull_width} ${hull_height}"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0.0" rpy="0 0 0"/>
      <mass value="15.0"/>
      <inertia
        ixx="1.0"
        ixy="0.0"
        ixz="0.0"
        iyy="1.0"
        iyz="0.0"
        izz="1.0"/>
    </inertial>
  </link>

  <!-- Camera frame -->
  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${camera_size} ${camera_size} ${camera_size}"/>
      </geometry>
      <material name="gray">
        <color rgba="0.4 0.4 0.4 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.30 0.0 0.14" rpy="0 0 0"/>
  </joint>

  <!-- Water plane -->
  <link name="water_plane">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${water_length} ${water_width} ${water_thickness}"/>
      </geometry>
      <material name="water_blue">
        <color rgba="0.0 0.35 0.65 0.55"/>
      </material>
    </visual>
  </link>

  <joint name="water_joint" type="fixed">
    <parent link="base_link"/>
    <child link="water_plane"/>
    <origin xyz="0 0 -0.12" rpy="0 0 0"/>
  </joint>

</robot>